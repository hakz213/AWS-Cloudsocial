@app.get("/post")
def post_redirect():
	return RedirectResponse("/", status_code=303)


@app.post("/post")
def create_post(user: str = Form(...), content: str = Form(...)):
	conn = sqlite3.connect("cloudsocial.db")
	cursor = conn.cursor()
	cursor.execute(
		"INSERT INTO posts (user, content) VALUES (?, ?)",
		(user, content)

	)
	conn.commit()
	conn.close()	



	return RedirectResponse("/", status_code=303)
